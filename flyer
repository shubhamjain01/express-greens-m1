    <div class="hl-item">
      <span class="hl-icon">🎖️</span>
      <div class="hl-num">7</div>
      <div class="hl-label">Dedicated<br>Members</div>
    </div>
    <div class="hl-item">
      <span class="hl-icon">🏛️</span>
      <div class="hl-num">4</div>
      <div class="hl-label">Core<br>Pillars</div>
    </div>
    <div class="hl-item">
      <span class="hl-icon">🤝</span>
      <div class="hl-num">1</div>
      <div class="hl-label">United<br>Mission</div>
    </div>
  </div>

  <!-- Team -->
  <div class="team-area">
    <h3>Meet Our Team</h3>
    <p class="team-sub">Legal expertise &bull; Armed forces discipline &bull; Corporate finance &bull; Mega-project execution &bull; Community leadership</p>

    <!-- Top 3 -->
    <div class="leaders">
      <div class="member president">
        <img src="Images/Sukhvir.JPG" alt="Sukhvir">
